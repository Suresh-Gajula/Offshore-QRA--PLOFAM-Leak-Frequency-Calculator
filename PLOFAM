    def interpolate_parameters(D, diameters, C_values, m_values, B_values):
        if D in diameters:
            idx = diameters.index(D)
            return C_values[idx], m_values[idx], B_values[idx]
        else:
            # Find the two closest diameters to D
            smaller_d = max(d for d in diameters if d < D)
            larger_d = min(d for d in diameters if d > D)

            # Interpolate the parameters
            idx_smaller = diameters.index(smaller_d)
            idx_larger = diameters.index(larger_d)

            ratio = (D - smaller_d) / (larger_d - smaller_d)

            interpolated_C = C_values[idx_smaller] + ratio * (C_values[idx_larger] - C_values[idx_smaller])
            interpolated_m = m_values[idx_smaller] + ratio * (m_values[idx_larger] - m_values[idx_smaller])
            interpolated_B = B_values[idx_smaller] + ratio * (B_values[idx_larger] - B_values[idx_smaller])

            return interpolated_C, interpolated_m, interpolated_B

    def calculate_F(d, D):
        # Parameters based on equipment size interpolation
        diameters = [0, 170, 508]
        C_values = [2.99e-5, 1.39e-5, 1.87e-5]
        m_values = [-0.798, -0.872, -0.482]
        B_values = [0, 0, 6.69e-8]

        C, m, B = interpolate_parameters(D, diameters, C_values, m_values, B_values)

        # Calculate F(d) based on the provided equation
        if 1 < d <= D:
            return C * d ** m + B
        elif d > D:
            return 0
        else:
            return None  # Handle invalid input

