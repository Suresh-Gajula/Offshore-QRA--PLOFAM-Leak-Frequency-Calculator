class EquipmentDialog(simpledialog.Dialog):
    available_phases = ['Gas', 'Liquid']

    def __init__(self, parent, title, available_equipment):
        self.available_equipment = available_equipment
        super().__init__(parent, title)

    def body(self, master):
        self.result_var = tk.StringVar()
        self.result_var.set(self.available_equipment[0])

        label = tk.Label(master, text="Select Equipment:")
        label.pack()

        equipment_dropdown = ttk.Combobox(master, textvariable=self.result_var, values=self.available_equipment)
        equipment_dropdown.pack()
        equipment_dropdown.focus_force()

        self.phase_var = tk.StringVar()
        self.number_var = tk.StringVar()
        self.size_var = tk.StringVar()
        self.pressure_var = tk.StringVar()
        self.density_var = tk.StringVar()
        self.hc_mass_fraction_var = tk.StringVar()

        phase_label = tk.Label(master, text="Phase (G/L):")
        phase_label.pack()
        phase_combobox = ttk.Combobox(master, textvariable=self.phase_var, values=self.available_phases)
        phase_combobox.pack()
        phase_combobox.set(self.available_phases[0])

        number_label = tk.Label(master, text="Number:")
        number_label.pack()
        number_entry = tk.Entry(master, textvariable=self.number_var)
        number_entry.pack()

        size_label = tk.Label(master, text="Size (mm):")
        size_label.pack()
        size_entry = tk.Entry(master, textvariable=self.size_var)
        size_entry.pack()

        pressure_label = tk.Label(master, text="Pressure (bar):")
        pressure_label.pack()
        pressure_entry = tk.Entry(master, textvariable=self.pressure_var)
        pressure_entry.pack()

        density_label = tk.Label(master, text="Density (kg/m³):")
        density_label.pack()
        density_entry = tk.Entry(master, textvariable=self.density_var)
        density_entry.pack()

        hc_mass_fraction_label = tk.Label(master, text="HC Mass Fraction:")
        hc_mass_fraction_label.pack()
        hc_mass_fraction_entry = tk.Entry(master, textvariable=self.hc_mass_fraction_var)
        hc_mass_fraction_entry.pack()

    def apply(self):
        self.result = {
            'equipment': self.result_var.get(),
            'phase': self.phase_var.get(),
            'number': self.number_var.get(),
            'size': self.size_var.get(),
            'pressure': self.pressure_var.get(),
            'density': self.density_var.get(),
            'hc_mass_fraction': self.hc_mass_fraction_var.get()
        }


class EditDialog(simpledialog.Dialog):
    def __init__(self, parent, title, existing_data):
        self.existing_data = existing_data
        super().__init__(parent, title)

    def body(self, master):
        self.result_var = tk.StringVar(value=self.existing_data)

        label = tk.Label(master, text="Edit Equipment:")
        label.pack()

        equipment_entry = tk.Entry(master, textvariable=self.result_var)
        equipment_entry.pack()

    def apply(self):
        self.result = self.result_var.get()


class CategoryDialog(simpledialog.Dialog):
    def __init__(self, parent, title, category_type):
        self.category_type = category_type
        super().__init__(parent, title)

    def body(self, master):
        self.from_var = tk.StringVar()
        self.to_var = tk.StringVar()

        from_label = tk.Label(master, text=f"From - {self.category_type}:")
        from_label.pack()
        from_entry = tk.Entry(master, textvariable=self.from_var)
        from_entry.pack()

        to_label = tk.Label(master, text=f"To - {self.category_type}:")
        to_label.pack()
        to_entry = tk.Entry(master, textvariable=self.to_var)
        to_entry.pack()

    def apply(self):
        self.result = {
            'from_value': self.from_var.get(),
            'to_value': self.to_var.get()
        }


