            self.treeview_input.insert(parent, "end", text=Sub_Segment_name)
        else:
            messagebox.showwarning("Invalid Operation",
                                   "Sub_Segments can only be added under a Segment, not in other Sub_Segments.")

    def add_area_input(self, Sub_Segment, area):
        if self.treeview_input.parent(Sub_Segment) and not self.treeview_input.parent(
                self.treeview_input.parent(Sub_Segment)):
            # Check if the selected item is an "Sub_Segment" under a "Segment"
            self.treeview_input.insert(Sub_Segment, "end", text=area)
        else:
            messagebox.showwarning("Invalid Operation",
                                   "Area can only be added under an Sub-Segment, not in other Area.")

