    # Function for Report tab
    def calculate_f_0_significant(self, equipment_type, size):
        # Retrieve equipment-specific constants
        constants = self.equipment_constants.get_constants(equipment_type)

        # Extract constants for the formula
        A_0 = constants.get('A_0', 1)
        M_0 = constants.get('M_0', 0)
        Fhist_Significant = constants.get('Fhist_Significant', 0)

        # Convert input values to float
        size = float(size)

        # Calculate F_0_significant using the provided formula
        f_0_significant = Fhist_Significant * (A_0 * size ** M_0)
        return f_0_significant

    def calculate_f_0_marginal(self, equipment_type, size):
        # Retrieve equipment-specific constants
        constants = self.equipment_constants.get_constants(equipment_type)

        # Extract constants for the formula
        A_0 = constants.get('A_0', 1)
        M_0 = constants.get('M_0', 0)
        Fhist_Marginal = constants.get('Fhist_Marginal', 0)

        size = float(size)
        f_0_marginal = Fhist_Marginal * (A_0 * size ** M_0)
        return f_0_marginal

    def calculate_f_d(self, equipment_type, size):
        constants = self.equipment_constants.get_constants(equipment_type)
        A_D = constants.get('A_D', 0)
        M_D = constants.get('M_D', 0)
        B_D = constants.get('B_D', 0)
        size = float(size)

        f_0_significant = self.calculate_f_0_significant(equipment_type, size)
        f_d = f_0_significant * (A_D * size ** M_D + B_D)
        return f_d

    def calculate_f_1(self, equipment_type, size):
        constants = self.equipment_constants.get_constants(equipment_type)
        alpha = constants.get('𝛼', 0)
        f_d = self.calculate_f_d(equipment_type, size)
        f_1 = alpha * f_d
        return f_1

    def calculate_hole_size_min(self, phase, total_leak_rate_min, density, pressure):
        if phase == 'Gas':
            hole_size_min_mm = math.sqrt(
                total_leak_rate_min / (1.41246e-4) / math.sqrt(float(density) * float(pressure)))
        elif phase == 'Liquid':
            hole_size_min_mm = math.sqrt(
                total_leak_rate_min / (2.14257e-4) / math.sqrt(float(density) * float(pressure)))
        else:
            hole_size_min_mm = 0

        return hole_size_min_mm

    def calculate_hole_size_max(self, phase, total_leak_rate_max, density, pressure):
        if phase == 'Gas':
            hole_size_max_mm = math.sqrt(
                total_leak_rate_max / (1.41246e-4) / math.sqrt(float(density) * float(pressure)))
        elif phase == 'Liquid':
            hole_size_max_mm = math.sqrt(
                total_leak_rate_max / (2.14257e-4) / math.sqrt(float(density) * float(pressure)))
        else:
            hole_size_max_mm = 0

        return hole_size_max_mm

    def calculate_freq_0_min(self, equipment_type, size, leak_type):
        # Retrieve equipment-specific constants
        constants = self.equipment_constants.get_constants(equipment_type)
        # Extract constants for the formula
        A_0 = constants.get('A_0', 1)
        M_0 = constants.get('M_0', 0)
        Fhist_Significant = constants.get('Fhist_Significant', 0)
        Fhist_Marginal = constants.get('Fhist_Marginal', 0)
        size = float(size)
        freq_0_min_significant = (Fhist_Significant * (A_0 * size ** M_0))
        freq_0_min_marginal = (Fhist_Marginal * (A_0 * size ** M_0))

        if leak_type == 'Significant Leak':
            freq_0_min = freq_0_min_significant
        elif leak_type == 'Marginal Leak':
            freq_0_min = freq_0_min_marginal
        elif leak_type == 'Total Leak':
            freq_0_min = freq_0_min_significant + freq_0_min_marginal
        else:
            freq_0_min = 0  # Set default value if leak type is not recognized

        return "{:.2E}".format(freq_0_min)

    def calculate_freq_0_max(self, equipment_type, size, leak_type):
        # Retrieve equipment-specific constants
        constants = self.equipment_constants.get_constants(equipment_type)
        # Extract constants for the formula
        A_0 = constants.get('A_0', 1)
        M_0 = constants.get('M_0', 0)
        Fhist_Significant = constants.get('Fhist_Significant', 0)
        Fhist_Marginal = constants.get('Fhist_Marginal', 0)
        size = float(size)
        freq_0_max_significant = (Fhist_Significant * (A_0 * size ** M_0))
        freq_0_max_marginal = (Fhist_Marginal * (A_0 * size ** M_0))

        if leak_type == 'Significant Leak':
            freq_0_max = freq_0_max_significant
        elif leak_type == 'Marginal Leak':
            freq_0_max = freq_0_max_marginal
        elif leak_type == 'Total Leak':
            freq_0_max = freq_0_max_significant + freq_0_max_marginal
        else:
            freq_0_max = 0  # Set default value if leak type is not recognized

        return "{:.2E}".format(freq_0_max)

    def calculate_freq_D_min(self, equipment_type, size, leak_type):
