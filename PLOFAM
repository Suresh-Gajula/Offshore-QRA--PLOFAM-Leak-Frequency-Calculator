        # Prompt the user to choose the save location path for the master Excel file
        master_save_path = filedialog.asksaveasfilename(defaultextension=".xlsx", filetypes=[("Excel files", "*.xlsx")])

        # If user cancels the operation or doesn't choose a file, return
        if not master_save_path:
            return

        # Load the existing master Excel file
        master_excel_path = "D:\MASTERS\SEM 4\MASTER THESIS\LEAK FREQUENCY\LEAK FREQUENCY\master_workbook.xlsx"
        wb_master = load_workbook(master_excel_path)

        # Get the active worksheet in the master Excel file
        ws_master = wb_master.active

        # Clear existing data in the master Excel sheet except heading row
        ws_master.delete_rows(2, ws_master.max_row)

        # Function to convert values to numbers
        def convert_to_number(value):
            if isinstance(value, str):
                try:
                    # Try converting directly to float
                    return float(value)
                except ValueError:
                    try:
                        # Try converting from scientific notation
                        return float(value)
                    except ValueError:
                        # If both conversion attempts fail, return the original value
                        return value
            else:
                # If it's not a string, return the original value
                return value

        # Traverse the Report tab treeview to extract data and append to the master worksheet
        for item_id in self.treeview_report.get_children():
            values = self.treeview_report.item(item_id, 'values')
            # Convert values to numbers
            converted_values = [convert_to_number(value) for value in values]
            # Append converted values to the worksheet
            ws_master.append(converted_values)

        # Save the master Excel file with the added data
        wb_master.save(master_save_path)

        # Display a message box indicating that the file has been saved
        messagebox.showinfo("File Saved", f"The file has been successfully saved at:\n{master_save_path}")


