                freq_0_min = self.calculate_freq_0_min(equipment_type, size, leak_type)
                # Calculate Freq_0_max with leak type
                freq_0_max = self.calculate_freq_0_max(equipment_type, size, leak_type)
                # Calculate Freq_D_min with leak type
                freq_D_min = self.calculate_freq_D_min(equipment_type, size, leak_type)
                # Calculate Freq_D_max with leak type
                freq_D_max = self.calculate_freq_D_max(equipment_type, size, leak_type)
                # Calculate m_D_min with leak type
                m_D_min = self.calculate_m_D_min(equipment_type, size, leak_type)
                # Calculate m_D_max with leak type
                m_D_max = self.calculate_m_D_max(equipment_type, size, leak_type)
