    def insert_leak_rate_intervals(self, segment, sub_segment, area, equipment_type, phase, number, size, pressure,
                                   density, hc_mass_fraction, leak_type, leak_rate, tag):
        intervals = ['Negligible', 'Small', 'Medium', 'Major', 'Large']
        for interval in intervals:
            # Fetch the value from the Output tab treeview based on the leak rate interval
            item_clicked = None
            if interval == 'Negligible':
                item_clicked = self.treeview_output.item(self.treeview_output.get_children()[0])['text']
            elif interval == 'Small':
                item_clicked = self.treeview_output.item(self.treeview_output.get_children()[1])['text']
            elif interval == 'Medium':
                item_clicked = self.treeview_output.item(self.treeview_output.get_children()[2])['text']
            elif interval == 'Major':
                item_clicked = self.treeview_output.item(self.treeview_output.get_children()[3])['text']
            elif interval == 'Large':
                item_clicked = self.treeview_output.item(self.treeview_output.get_children()[4])['text']

            if item_clicked:
                from_value = item_clicked.split(' - ')[-1].split(',')[0].split(':')[-1].strip()
                to_value = item_clicked.split(' - ')[-1].split(',')[1].split(':')[-1].strip()  # Extracting "To" value

